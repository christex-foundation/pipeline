# =============================================================================
# DPG Pipeline Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control
# See docs/DB_SETUP.md for detailed setup instructions

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =============================================================================
# Your Supabase project URL
# Get this from: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=""

# Your Supabase anonymous/public key
# Get this from: Supabase Dashboard > Settings > API > Project API keys > anon public
# Note: Keep the typo "SUPERBASE" to match the actual code usage
VITE_SUPERBASE_ANON_KEY=""

# Your Supabase service role key (KEEP SECRET - server-side only)
# Get this from: Supabase Dashboard > Settings > API > Project API keys > service_role
# WARNING: This key has admin privileges - never expose client-side
PRIVATE_SUPABASE_SERVICE_KEY=""
